{
  "cleanUrls": true,
  "rewrites": [
    { "source": "/api/github", "destination": "/api/github" },
    { "source": "/api/:path*", "destination": "/api/:path*" },
    { "source": "/painel", "destination": "/painel.html" },
    { "source": "/jotastore", "destination": "/Catalogo.html?loja=jotastore" },
    { "source": "/teste", "destination": "/Catalogo.html?loja=teste" }
  ]
}
